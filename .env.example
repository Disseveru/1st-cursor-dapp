# ============================================================
# Instadapp Arbitrage & Liquidation Bot - Environment Config
# ============================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# --- Wallet & DSA ---
# Private key of the dedicated hot wallet (NO 0x prefix).
# Use a fresh wallet that only holds gas funds (0.1-0.5 ETH).
PRIVATE_KEY=your_private_key_here

# Instadapp DeFi Smart Account ID to operate through.
DSA_ID=0

# --- RPC Endpoints (use premium QuickNode / Alchemy for speed) ---
RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# --- Flashbots ---
# Optional: leave blank to auto-generate an ephemeral signing key.
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
FLASHBOTS_AUTH_KEY=

# --- Kill-Switch ---
# Minimum ETH balance in the gas wallet before the bot halts.
MIN_ETH_BALANCE=0.05

# --- Monitoring Intervals (milliseconds) ---
POLL_INTERVAL_ARB=3000
POLL_INTERVAL_LIQ=5000
POLL_INTERVAL_CROSS_CHAIN=10000

# --- Profit Thresholds (in ETH) ---
MIN_PROFIT_ARB=0.005
MIN_PROFIT_LIQ=0.01

# --- Encryption (optional layer for private key at rest) ---
# When ENCRYPT_KEY_AT_REST=true the bot will AES-encrypt the
# private key on first run and read the cipher from KEY_FILE.
ENCRYPT_KEY_AT_REST=false
KEY_ENCRYPTION_PASSWORD=
KEY_FILE=.encrypted_key

# --- AWS Secrets Manager (alternative to .env private key) ---
# Set USE_AWS_SECRETS=true to pull PRIVATE_KEY from AWS SM.
USE_AWS_SECRETS=false
AWS_SECRET_NAME=instadapp-bot/private-key
AWS_REGION=us-east-1

# --- Logging ---
LOG_LEVEL=info
