# ---------------------------
# Core runtime
# ---------------------------
LOG_LEVEL=info
POLL_INTERVAL_MS=2500
BLOCK_LISTENER=false
RUN_ONCE=false
DRY_RUN=true
WEB_DASHBOARD_ENABLED=false
WEB_HOST=0.0.0.0
WEB_PORT=3000

# ---------------------------
# DSA + wallet
# ---------------------------
DSA_ID=1
ETHEREUM_RPC_URL=https://your-mainnet-quicknode-or-alchemy
QUICKNODE_RPC_URL=
ALCHEMY_RPC_URL=

# You can set one of the three private key sources below:
#
# 1) Plain key (development only)
# PRIVATE_KEY=0xyour_hot_wallet_key
#
# 2) Encrypted env payload + passphrase
# PRIVATE_KEY_ENCRYPTED=
# ENV_ENCRYPTION_KEY=
#
# 3) AWS Secrets Manager
# PRIVATE_KEY_SECRET_ID=
# AWS_REGION=us-east-1

# Optional origin tag for Instadapp analytics
DSA_ORIGIN=0x0000000000000000000000000000000000000000

# ---------------------------
# Additional chain RPCs
# ---------------------------
BASE_RPC_URL=https://your-base-rpc
ARBITRUM_RPC_URL=https://your-arbitrum-rpc
AVOCADO_RPC_URL=https://rpc.avocado.instadapp.io

# Optional full map (overrides / extends the chain URLs above)
# CHAIN_RPC_JSON={"1":"https://...","8453":"https://...","42161":"https://...","634":"https://rpc.avocado.instadapp.io"}
CHAIN_RPC_JSON={}

# ---------------------------
# Strategy and risk controls
# ---------------------------
GAS_KILL_SWITCH_ETH=0.05
MIN_PROFIT_ETH=0.002
GAS_MULTIPLIER=1.15
# Multiply observed network gas bid before tx construction (e.g. 1.3 = +30%)
GAS_PRICE_MULTIPLIER=1.0
# Optional priority tip (gwei) for direct/Flashbots execution path
PRIORITY_TIP_GWEI=0
FLASHLOAN_ROUTE=0

# ---------------------------
# Flashbots / MEV protection
# ---------------------------
USE_FLASHBOTS=true
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
FLASHBOTS_AUTH_PRIVATE_KEY=
FLASHBOTS_MAX_BLOCKS=6
ALLOW_PUBLIC_MEMPOOL_FALLBACK=false

# ---------------------------
# Monitors
# ---------------------------
# Arbitrage pair format:
# [
#   {
#     "label":"DAI/USDC mainnet",
#     "chainId":1,
#     "tokenIn":"0x6B175474E89094C44Da98b954EedeAC495271d0F",
#     "tokenOut":"0xA0b86991c6218b36c1d19d4a2e9eb0ce3606eb48",
#     "tokenInDecimals":18,
#     "tokenOutDecimals":6,
#     "amountIn":"25000",
#     "minProfitBps":8,
#     "nativeQuote":{"quoter":"0xb27308f9F90D607463bb33eA1BeBb41C27CE5AB6","fee":500},
#     "sources":{
#       "uniswapV3":{"quoter":"0xb27308f9F90D607463bb33eA1BeBb41C27CE5AB6","fee":100,"enabled":true},
#       "sushiswap":{"router":"0xd9e1cE17f2641f24aE83637ab66a2cca9C378B9F","enabled":true},
#       "curve":{"pool":"0xbEbC44782C7dB0a1A60Cb6Fe97d0b483032FF1C7","tokenInIndex":0,"tokenOutIndex":1,"enabled":true}
#     }
#   }
# ]
ARBITRAGE_PAIRS_JSON=[]

# Liquidation positions format:
# [
#   {
#     "label":"Aave borrower #1",
#     "protocol":"aave-v3",
#     "chainId":1,
#     "poolAddress":"0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2",
#     "borrower":"0x...",
#     "liquidationHealthFactor":1,
#     "repayToken":"0xA0b86991c6218b36c1d19d4a2e9eb0ce3606eb48",
#     "collateralToken":"0xC02aaA39b223FE8D0A0E5C4F27eAD9083C756Cc2",
#     "flashLoanAmount":"10000",
#     "flashLoanDecimals":6,
#     "expectedProfitEth":"0.01"
#   }
# ]
LIQUIDATION_POSITIONS_JSON=[]

# Cross-chain spread format:
# [
#   {
#     "label":"USDC/WETH Mainnet vs Base",
#     "baseChainId":1,
#     "compareChainId":8453,
#     "tokenInDecimals":6,
#     "amountIn":"5000",
#     "minSpreadBps":20,
#     "tokenInByChain":{"1":"0xA0b86991c6218b36c1d19d4a2e9eb0ce3606eb48","8453":"0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"},
#     "tokenOutByChain":{"1":"0xC02aaA39b223FE8D0A0E5C4F27eAD9083C756Cc2","8453":"0x4200000000000000000000000000000000000006"},
#     "source":{"name":"uniswapV3","fee":500,"quoterByChain":{"1":"0xb27308f9F90D607463bb33eA1BeBb41C27CE5AB6","8453":"0x3d4e44Eb1374240CE5F1B871ab261CD16335B76a"}},
#     "expectedProfitEth":"0.01"
#   }
# ]
CROSS_CHAIN_PAIRS_JSON=[]

# ---------------------------
# Avocado cross-chain balance fetching
# ---------------------------
AVOCADO_ENABLED=true
AVOCADO_BALANCE_CHAINS_JSON=[1,8453,42161]
AVOCADO_TRACK_TOKENS=false
AVOCADO_TOKENS_BY_CHAIN_JSON={}

# ---------------------------
# Avocado execution mode (optional)
# ---------------------------
# When enabled, transactions are sent through Avocado instead of direct EOA broadcast.
AVOCADO_EXECUTION_ENABLED=false
# Optional: force a specific Avocado safe address. Leave blank to auto-derive from PRIVATE_KEY owner.
AVOCADO_SAFE_ADDRESS=
# Default target execution chain for Avocado relay sends.
AVOCADO_EXECUTION_CHAIN_ID=1
# Optional Avocado signature fields.
AVOCADO_TX_VALID_UNTIL=0
AVOCADO_TX_GAS=0
AVOCADO_TX_SOURCE=0x000000000000000000000000000000000000Cad0
AVOCADO_TX_ID=0
# Set only if you need to force safe version handling
AVOCADO_TX_VERSION=

# ---------------------------
# Spell templates (Instadapp connectors)
# ---------------------------
# Optional override for the default arbitrage/liquidation/cross-chain templates.
# You can also provide liquidation templates by protocol:
# EXECUTION_TEMPLATES_JSON={"arbitrageInnerSteps":[...],"liquidationInnerSteps":[...],"liquidationInnerStepsByProtocol":{"compound-v2":[...],"aave-v3":[...]},"crossChainInnerSteps":[...]}
EXECUTION_TEMPLATES_JSON=

# Optional bridge placeholders for cross-chain template usage
BRIDGE_CONNECTOR=
BRIDGE_METHOD=
BRIDGE_ARGS_JSON=[]
