# ============================================================
# Instadapp Arbitrage & Liquidation Bot — Environment Variables
# ============================================================
# Copy to .env and fill in real values. NEVER commit .env.

# --- Wallet & DSA ---
# A *dedicated* hot-wallet private key (no 0x prefix).
# Only fund this wallet with enough ETH for gas (0.1–0.5 ETH).
PRIVATE_KEY=your_64_char_hex_private_key_here
DSA_ID=0

# --- RPC Endpoints (QuickNode / Alchemy) ---
RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY
RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# --- Flashbots ---
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
FLASHBOTS_AUTH_SIGNER_KEY=

# --- Kill-Switch ---
# Minimum ETH balance (in ether) before the bot halts.
MIN_ETH_BALANCE=0.05

# --- Monitoring ---
# Polling interval in milliseconds.
POLL_INTERVAL_MS=2000

# --- Profit Thresholds (in ETH) ---
MIN_PROFIT_THRESHOLD=0.005

# --- Encryption (optional) ---
# If set, the bot encrypts/decrypts PRIVATE_KEY at rest using AES-256-GCM.
ENV_ENCRYPTION_KEY=

# --- Logging ---
LOG_LEVEL=info
