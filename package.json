{
  "name": "instadapp-autonomous-searcher-bot",
  "version": "1.0.0",
  "description": "Node.js autonomous searcher bot for Instadapp DSA flash-loan arbitrage and liquidations",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:web": "WEB_DASHBOARD_ENABLED=true node src/index.js",
    "start:once": "node src/index.js --once",
    "dry-run": "node src/index.js --dry-run --once",
    "check": "node -e \"require('./src/index.js')\"",
    "encrypt:key": "node scripts/encrypt-env.js",
    "test": "jest --verbose",
    "test:ci": "jest --ci --coverage",
    "lint": "eslint src/ test/ scripts/",
    "lint:fix": "eslint src/ test/ scripts/ --fix",
    "format": "prettier --write 'src/**/*.js' 'test/**/*.js' 'scripts/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'test/**/*.js' 'scripts/**/*.js'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Disseveru/1st-cursor-dapp.git"
  },
  "keywords": [
    "instadapp",
    "dsa",
    "searcher",
    "flashloan",
    "arbitrage",
    "liquidation",
    "flashbots",
    "defi"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/Disseveru/1st-cursor-dapp/issues"
  },
  "homepage": "https://github.com/Disseveru/1st-cursor-dapp#readme",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.994.0",
    "@flashbots/ethers-provider-bundle": "^1.0.0",
    "@instadapp/avocado": "^0.4.5",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "dsa-sdk": "^1.5.15",
    "ethers": "^6.7.1",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "web3": "^1.10.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.8.1"
  }
}
